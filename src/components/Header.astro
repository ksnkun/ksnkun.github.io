---
import { siteConfig } from "../config/site.ts";

const navLinks = [
  { label: "Обо мне", href: "#about" },
  { label: "Портфолио", href: "#portfolio" },
  { label: "Контакты", href: "#contacts" },
];
---

<header>
  <div class="container">
    <div class="header-content">
      <a href="#" class="logo">
        <h3 class="logo-content">{siteConfig.author}</h3>
      </a>

      <button
        class="mobile-menu-toggle"
        aria-label="Toggle menu"
        id="mobileMenuBtn"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>

      <nav id="navMenu">
        <ul class="nav-menu">
          {
            navLinks.map((link) => (
              <li>
                <a href={link.href}>{link.label}</a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>
  </div>
</header>

<script>
  const menuBtn = document.getElementById("mobileMenuBtn");
  const navMenu = document.getElementById("navMenu");

  if (menuBtn && navMenu) {
    menuBtn.addEventListener("click", () => {
      navMenu.classList.toggle("active");
      menuBtn.classList.toggle("active");
    });

    const navLinks = navMenu.querySelectorAll("a");
    navLinks.forEach((link) => {
      link.addEventListener("click", () => {
        navMenu.classList.remove("active");
        menuBtn.classList.remove("active");
      });
    });

    navMenu.addEventListener("click", (e) => {
      if (e.target?.tagName != "a") {
        navMenu.classList.remove("active");
        menuBtn.classList.remove("active");
      }
    });
  }
</script>

<style>
  header {
    background-color: var(--color-dark);
    padding: var(--space-lg) 0;
    box-shadow: var(--shadow-sm);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-lg);
  }

  .logo {
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo h3 {
    margin: 0;
    color: var(--color-primary);
    font-size: var(--font-size-xl);
    transition: color var(--transition-base);
  }

  .logo h3:hover {
    color: var(--color-accent);
  }

  nav {
    display: flex;
  }

  .nav-menu {
    display: flex;
    gap: var(--space-2xl);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-menu li {
    display: flex;
  }

  .nav-menu a {
    color: var(--color-primary);
    font-weight: var(--font-weight-semibold);
    transition: color var(--transition-base);
    text-decoration: none;
    white-space: nowrap;
  }

  .nav-menu a:hover {
    color: var(--color-accent);
  }

  .mobile-menu-toggle {
    display: none;
    flex-direction: column;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-sm);
    gap: var(--space-sm);
    z-index: 102;
    position: relative;
    margin: calc(var(--space-sm) * -1);
    flex-shrink: 0;
  }

  .mobile-menu-toggle span {
    width: 2rem;
    height: 0.25rem;
    background-color: var(--color-primary);
    border-radius: var(--radius-sm);
    transition: all var(--transition-base);
    display: block;
  }

  .mobile-menu-toggle.active span:nth-child(1) {
    transform: rotate(45deg)
      translate(calc(var(--space-sm) * 1.5), calc(var(--space-sm) * 1.5));
  }

  .mobile-menu-toggle.active span:nth-child(2) {
    opacity: 0;
  }

  .mobile-menu-toggle.active span:nth-child(3) {
    transform: rotate(-45deg)
      translate(calc(var(--space-sm) * 0.75), calc(var(--space-sm) * -0.75));
  }

  @media (max-width: 768px) {
    .header-content {
      gap: var(--space-md);
    }

    .mobile-menu-toggle {
      display: flex;
    }

    nav {
      position: fixed;
      inset: 0;
      width: 100%;
      height: 100%;
      background-color: var(--color-dark);
      left: -100%;
      transition: left var(--transition-base);
      z-index: 101;
      overflow-y: auto;
      padding-top: 0;
    }

    nav.active {
      left: 0;
    }

    .nav-menu {
      flex-direction: column;
      gap: 0;
      padding: var(--space-xl) var(--space-lg);
      margin: 0;
    }

    .nav-menu li {
      display: flex;
      flex-direction: column;
    }

    .nav-menu a {
      padding: var(--space-lg) 0;
      font-size: var(--font-size-lg);
      border-bottom: 1px solid rgba(251, 222, 156, 0.1);
      width: 100vw;
      margin-left: calc(var(--space-lg) * -1);
      padding-left: var(--space-lg);
      display: block;
    }

    .nav-menu li:first-child a {
      padding-top: calc(var(--space-lg) * 2);
    }

    .nav-menu a:active {
      color: var(--color-accent);
    }
  }

  @media (max-width: 480px) {
    header {
      padding: var(--space-md) 0;
    }

    .logo h3 {
      font-size: var(--font-size-lg);
    }

    .nav-menu a {
      font-size: var(--font-size-base);
    }
  }
</style>
